# ============================================================
# Observability PoC - Environment Variables
# cp .env.example .env && vi .env
# ============================================================

# AWS Settings
AWS_REGION=ap-northeast-1
AWS_ACCOUNT_ID=123456789012

# EKS Cluster
CLUSTER_NAME=obs-poc

# ECR Registry (set after terraform apply)
ECR_REGISTRY=123456789012.dkr.ecr.ap-northeast-1.amazonaws.com

# New Relic
NEW_RELIC_LICENSE_KEY=your_license_key_here
NEW_RELIC_API_KEY=NRAK-your_api_key_here
NEW_RELIC_ACCOUNT_ID=your_account_id_here
NEW_RELIC_REGION=US

# New Relic OTLP Endpoint
# US: otlp.nr-data.net:4317
# EU: otlp.eu01.nr-data.net:4317
NEW_RELIC_OTLP_ENDPOINT=otlp.nr-data.net:4317

# CloudWatch RUM (set after terraform apply)
CW_RUM_APP_MONITOR_ID=your_app_monitor_id
CW_RUM_IDENTITY_POOL_ID=your_identity_pool_id
CW_RUM_REGION=ap-northeast-1

# CloudWatch Synthetics
SYNTHETICS_CANARY_URL=http://localhost:8080

# Terraform state (optional S3 backend)
# TF_STATE_BUCKET=obs-poc-tfstate
# TF_STATE_KEY=terraform.tfstate
