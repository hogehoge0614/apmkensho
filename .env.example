# ============================================================
# Observability PoC - Environment Variables
# cp .env.example .env && vi .env
# ============================================================

# AWS Settings
AWS_REGION=ap-northeast-1
AWS_ACCOUNT_ID=123456789012

# EKS Cluster
CLUSTER_NAME=obs-poc

# ECR Registry (terraform apply 後に設定)
# terraform output ecr_registry
ECR_REGISTRY=123456789012.dkr.ecr.ap-northeast-1.amazonaws.com

# ============================================================
# New Relic
# https://one.newrelic.com → Administration → API keys
# ============================================================

# INGEST - LICENSE タイプのキー
NEW_RELIC_LICENSE_KEY=your_license_key_here

# USER タイプのキー (NRAK- で始まる)
NEW_RELIC_API_KEY=NRAK-your_api_key_here

# Administration → API keys ページの Account ID
NEW_RELIC_ACCOUNT_ID=your_account_id_here

# ログイン URL が one.newrelic.com → US / one.eu.newrelic.com → EU
NEW_RELIC_REGION=US

# NR Browser を使う場合に New Relic Browser の JavaScript snippet 全体を設定
# 設定後: make create-secrets && make ec2-newrelic-deploy
NR_BROWSER_SNIPPET=

# ============================================================
# CloudWatch RUM (terraform apply 後に設定)
# 取得コマンド:
#   terraform -chdir=infra/terraform output rum_app_monitor_id
#   terraform -chdir=infra/terraform output cognito_identity_pool_id
# 設定後: make ec2-appsignals-enable-rum
# Fargate 側にも入れる場合: make fargate-appsignals-enable-rum
# ============================================================

# RUM App Monitor の ID (UUID 形式)
CW_RUM_APP_MONITOR_ID=your_app_monitor_id

# Cognito Identity Pool ID (ap-northeast-1:xxxx-xxxx-... 形式)
CW_RUM_IDENTITY_POOL_ID=your_identity_pool_id

CW_RUM_REGION=ap-northeast-1

# ============================================================
# カスタムメトリクス (StatsD → CloudWatch Agent → CloudWatch)
# 設定後: make ec2-appsignals-enable-custom-metrics
# ============================================================

# StatsD ポート (CloudWatch Agent が UDP で待ち受け)
STATSD_PORT=8125

# CloudWatch のメトリクス名前空間
CUSTOM_METRICS_NAMESPACE=NetwatchPoC/Custom

# ============================================================
# アプリ URL (各環境のデプロイ後に LoadBalancer hostname を設定)
# make load はここに設定した全 URL にトラフィックを送信する
# ============================================================

# EKS on EC2 + App Signals
EC2_AS_BASE=http://your-ec2-as-elb-hostname.ap-northeast-1.elb.amazonaws.com

# EKS on Fargate + App Signals
FARGATE_AS_BASE=http://your-fargate-as-elb-hostname.ap-northeast-1.elb.amazonaws.com

# EKS on EC2 + New Relic
EC2_NR_BASE=http://your-ec2-nr-elb-hostname.ap-northeast-1.elb.amazonaws.com

# EKS on Fargate + New Relic (APM only)
FARGATE_NR_BASE=http://your-fargate-nr-elb-hostname.ap-northeast-1.elb.amazonaws.com

# ============================================================
# CloudWatch Synthetics
# 死活監視対象 URL。EC2_AS_BASE と同じ値を設定し terraform apply で反映する
# ============================================================
SYNTHETICS_CANARY_URL=http://your-ec2-elb-hostname.ap-northeast-1.elb.amazonaws.com

# ============================================================
# Terraform state (S3 backend を使う場合のみ設定)
# ============================================================
# TF_STATE_BUCKET=obs-poc-tfstate
# TF_STATE_KEY=terraform.tfstate
