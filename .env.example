# ============================================================
# Observability PoC - Environment Variables
# cp .env.example .env && vi .env
# ============================================================

# AWS Settings
AWS_REGION=ap-northeast-1
AWS_ACCOUNT_ID=123456789012

# EKS Cluster
CLUSTER_NAME=obs-poc

# ECR Registry (terraform apply 後に設定)
# terraform output ecr_registry
ECR_REGISTRY=123456789012.dkr.ecr.ap-northeast-1.amazonaws.com

# ============================================================
# New Relic
# https://one.newrelic.com → Administration → API keys
# ============================================================

# INGEST - LICENSE タイプのキー
NEW_RELIC_LICENSE_KEY=your_license_key_here

# USER タイプのキー (NRAK- で始まる)
NEW_RELIC_API_KEY=NRAK-your_api_key_here

# Administration → API keys ページの Account ID
NEW_RELIC_ACCOUNT_ID=your_account_id_here

# ログイン URL が one.newrelic.com → US / one.eu.newrelic.com → EU
NEW_RELIC_REGION=US

# ============================================================
# CloudWatch RUM (terraform apply 後に設定)
# 取得コマンド:
#   terraform -chdir=infra/terraform output rum_app_monitor_id
#   terraform -chdir=infra/terraform output cognito_identity_pool_id
# ============================================================

# RUM App Monitor の ID (UUID 形式)
CW_RUM_APP_MONITOR_ID=your_app_monitor_id

# Cognito Identity Pool ID (ap-northeast-1:xxxx-xxxx-... 形式)
CW_RUM_IDENTITY_POOL_ID=your_identity_pool_id

CW_RUM_REGION=ap-northeast-1

# ============================================================
# CloudWatch Synthetics
# ============================================================

# Synthetics の死活監視対象 URL (EKS デプロイ後に LoadBalancer の hostname を設定)
# kubectl get svc frontend-ui -n demo-ec2 -o jsonpath='{.status.loadBalancer.ingress[0].hostname}'
# 設定後: terraform -chdir=infra/terraform apply -var="synthetics_canary_url=http://<hostname>"
SYNTHETICS_CANARY_URL=http://your-elb-hostname.ap-northeast-1.elb.amazonaws.com

# ============================================================
# Terraform state (S3 backend を使う場合のみ設定)
# ============================================================
# TF_STATE_BUCKET=obs-poc-tfstate
# TF_STATE_KEY=terraform.tfstate
